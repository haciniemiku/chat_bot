# DeepSeek API 配置
# 请在此处填入您自己的 API 密钥
# 获取 API 密钥：https://platform.deepseek.com/api_keys
API_KEY=your_deepseek_api_key_here
BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

# 调试模式设置
# true: 显示调试信息，false: 隐藏调试信息（生产环境推荐）
DEBUG_MODE=false

# 注意：
# 1. 每个用户应该使用自己的 API 密钥
# 2. 不要共享您的 API 密钥给他人
# 3. API 密钥有使用限制，请合理使用
# 4. 定期检查 API 使用情况